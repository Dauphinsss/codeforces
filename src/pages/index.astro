---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import DifficultyBadge from '@/components/DifficultyBadge.astro';
import GlossaryTooltip from '@/components/GlossaryTooltip';
import { ArrowRight, CalendarDays, ClipboardCheck, Code2, Megaphone, Send, Sparkles, Trophy, UsersRound } from 'lucide-react';
import { contests } from '@/data/contests';
import { problems } from '@/data/problems';
import { users } from '@/data/users';
import { rankClass } from '@/utils/accessibility';

const upcoming = contests.filter((contest) => contest.phase === 'proximo').slice(0, 3);
const topUsers = [...users].sort((a, b) => b.rating - a.rating).slice(0, 5);
const featured = problems.slice(0, 5);
---

<BaseLayout title="Inicio">
  <Breadcrumbs items={[]} />
  <div class="grid gap-6">
    <section class="hero" aria-labelledby="home-title">
      <p class="section-label">Programacion competitiva</p>
      <h1 id="home-title" class="mt-2 max-w-3xl">
        Entrena, compite y sigue tu progreso.
      </h1>
      <p class="text-muted-strong mt-3 max-w-2xl text-base">
        Resuelve problemas por dificultad, participa en contests y revisa tus envios recientes desde un solo lugar.
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <a class="btn btn-primary" href="/problemset" data-tour="primary-action"><Trophy aria-hidden="true" size={17} />Explorar problemas</a>
        <a class="btn" href="/contests"><CalendarDays aria-hidden="true" size={17} />Ver contests</a>
        <a class="btn btn-ghost" href="/register"><UsersRound aria-hidden="true" size={17} />Crear cuenta</a>
      </div>
      <dl class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="stat-card"><dt class="flex items-center gap-1.5"><Code2 aria-hidden="true" size={16} />Problemas</dt><dd>{problems.length}+</dd></div>
        <div class="stat-card"><dt class="flex items-center gap-1.5"><CalendarDays aria-hidden="true" size={16} />Contests</dt><dd>{contests.length}</dd></div>
        <div class="stat-card"><dt class="flex items-center gap-1.5"><UsersRound aria-hidden="true" size={16} />Coders activos</dt><dd>{users.length * 2400}</dd></div>
        <div class="stat-card"><dt class="flex items-center gap-1.5"><Sparkles aria-hidden="true" size={16} />Rondas</dt><dd>{contests.filter((contest) => contest.phase === 'proximo').length}</dd></div>
      </dl>
    </section>

    <div class="grid gap-6 lg:grid-cols-[1.6fr_1fr]">
      <div class="grid gap-6">
        <section class="panel-elevated p-6" aria-labelledby="quick-start-title" data-tour="content-card">
          <h2 id="quick-start-title" class="flex items-center gap-2 text-2xl">
            <Sparkles aria-hidden="true" size={24} />
            Ruta rapida
          </h2>
          <ol class="mt-4 grid gap-3 md:grid-cols-3">
            <li class="panel p-4">
              <p class="chip chip-soft">1</p>
              <h3 class="mt-3 text-base">Elegir problema</h3>
              <p class="text-muted-strong mt-1 text-sm">Filtra por tag o dificultad y abre una tarjeta.</p>
            </li>
            <li class="panel p-4">
              <p class="chip chip-soft">2</p>
              <h3 class="mt-3 text-base">Leer restricciones</h3>
              <p class="text-muted-strong mt-1 text-sm">Revisa tiempo, memoria, ejemplos y dificultad numerica.</p>
            </li>
            <li class="panel p-4">
              <p class="chip chip-soft">3</p>
              <h3 class="mt-3 text-base">Enviar solucion</h3>
              <p class="text-muted-strong mt-1 text-sm">Pega tu codigo, elige lenguaje y revisa el resultado del juez.</p>
            </li>
          </ol>
        </section>

        <section class="panel-elevated p-6" aria-labelledby="announcements-title" data-tour="content-card">
          <div class="flex items-center justify-between gap-3">
            <h2 id="announcements-title" class="flex items-center gap-2 text-2xl">
              <Megaphone aria-hidden="true" size={24} />
              Anuncios
            </h2>
            <span class="chip chip-soft">Hoy</span>
          </div>
          <div class="mt-4 grid gap-4">
            <article
              class="surface-primary-soft rounded-lg border p-4"
            >
              <p class="text-primary text-xs font-bold uppercase tracking-wider">Nuevo</p>
              <h3 class="mt-1">Ronda global abierta</h3>
              <p class="text-muted-strong mt-1 text-sm">
                Participa en una ronda de 2 horas con problemas de implementacion, grafos y estructuras de datos.
              </p>
            </article>
            <article
              class="surface-accent-soft rounded-lg border p-4"
            >
              <p class="text-accent text-xs font-bold uppercase tracking-wider">Funcion</p>
              <h3 class="mt-1">Nuevo set educativo</h3>
              <p class="text-muted-strong mt-1 text-sm">
                Practica busqueda binaria, prefijos y greedy con problemas ordenados por dificultad.
              </p>
            </article>
          </div>
        </section>

        <section aria-labelledby="featured-title" class="panel-elevated p-6">
          <div class="flex items-center justify-between">
            <h2 id="featured-title" class="flex items-center gap-2 text-2xl">
              <ClipboardCheck aria-hidden="true" size={24} />
              Problemas destacados
            </h2>
            <a class="inline-flex min-h-11 items-center gap-1 text-sm font-semibold" href="/problemset">Ver todos <ArrowRight aria-hidden="true" size={16} /></a>
          </div>
          <ul class="mt-4 grid gap-2">
            {featured.map((problem) => (
              <li>
                <a
                  href={`/problemset/problem/${problem.id}`}
                  class="text-app panel panel-hover flex items-center justify-between gap-4 p-4 no-underline"
                >
                  <div class="min-w-0">
                    <p class="text-muted text-xs font-bold">#{problem.id}</p>
                    <h3 class="mt-0.5 truncate text-base">{problem.title}</h3>
                    <div class="mt-2 flex flex-wrap gap-1.5">
                      {problem.tags.slice(0, 3).map((tag) => <span class="chip">{tag}</span>)}
                    </div>
                  </div>
                  <div class="flex shrink-0 flex-col items-end gap-1">
                    <DifficultyBadge difficulty={problem.difficulty} />
                    <p class="text-muted text-xs">{problem.solvedCount.toLocaleString('es')} resueltos</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <aside class="grid gap-6" aria-label="Resumen lateral">
        <section class="panel-elevated p-6" aria-labelledby="contests-title">
          <h2 id="contests-title" class="flex items-center gap-2 text-xl">
            <CalendarDays aria-hidden="true" size={21} />
            Proximos contests
          </h2>
          <ul class="mt-3 grid gap-3">
            {upcoming.map((contest) => (
              <li class="border-app rounded-md border p-3">
                <h3 class="text-base"><a href="/contests" class="no-underline hover:underline">{contest.name}</a></h3>
                <p class="text-muted mt-1 text-xs">
                  <span class="chip chip-soft">{contest.format}</span>
                  <span class="ml-2">{contest.startTime}</span>
                </p>
                <p class="text-muted mt-1 text-xs">Duracion {contest.duration}</p>
              </li>
            ))}
          </ul>
        </section>

        <section class="panel-elevated p-6" aria-labelledby="top-title">
          <h2 id="top-title" class="flex items-center gap-2 text-xl">
            <Trophy aria-hidden="true" size={21} />
            Top rated
          </h2>
          <p class="text-muted mt-1 text-sm">
            <GlossaryTooltip client:load term="rating" description="Puntaje numerico que estima rendimiento competitivo. Sube o baja despues de contests oficiales." />
          </p>
          <ol class="mt-3 grid gap-1.5">
            {topUsers.map((user, index) => (
              <li class="row-soft flex min-h-11 items-center gap-3 rounded-md p-2">
                <span
                  aria-hidden="true"
                  class="index-badge grid h-7 w-7 place-items-center rounded-full text-xs font-bold"
                >
                  {index + 1}
                </span>
                <a class={`flex-1 truncate font-bold no-underline ${rankClass(user.rank)}`} href={`/profile/${user.handle}`}>
                  {user.handle}
                </a>
                <span class="chip">{user.rating}</span>
              </li>
            ))}
          </ol>
        </section>
      </aside>
    </div>
  </div>
</BaseLayout>
