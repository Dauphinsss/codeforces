---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import AuthForm from '@/components/AuthForm';
import { UserRoundPlus } from 'lucide-react';
---

<BaseLayout title="Registro">
  <section class="grid gap-5" aria-labelledby="register-title">
    <Breadcrumbs items={[{ label: 'Registro' }]} />
    <header class="hero">
      <p class="section-label">Nueva cuenta</p>
      <h1 id="register-title" class="mt-2 flex items-center gap-2">
        <UserRoundPlus aria-hidden="true" size={32} />
        Crear cuenta
      </h1>
      <p class="text-muted-strong mt-2">
        Elige tu handle publico y completa los datos de acceso para entrar a la demo.
      </p>
    </header>
    <AuthForm client:load mode="register" />
    <p class="text-muted text-center text-sm">
      ¿Ya tenes cuenta? <a href="/enter" class="font-semibold">Entrar</a>
    </p>
  </section>
</BaseLayout>
