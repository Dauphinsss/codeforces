---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DifficultyBadge from '@/components/DifficultyBadge.astro';
import SubmitForm from '@/components/SubmitForm';
import { problems } from '@/data/problems';

export function getStaticPaths() {
  return problems.map((problem) => ({ params: { id: problem.id }, props: { problem } }));
}

const { problem } = Astro.props;
---

<BaseLayout title={`${problem.id}. ${problem.title}`}>
  <article class="grid gap-6">
    <nav aria-label="Migas de pan" class="text-sm" style="color: var(--color-muted);">
      <a href="/problemset" class="hover:underline">Problemset</a>
      <span aria-hidden="true"> / </span>
      <span>#{problem.id}</span>
    </nav>

    <header class="hero">
      <p class="section-label">Problema #{problem.id}</p>
      <h1 class="mt-2">{problem.title}</h1>
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <DifficultyBadge difficulty={problem.difficulty} showLabel={true} />
        {problem.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
      <dl class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="stat-card"><dt>Tiempo</dt><dd class="text-base">{problem.timeLimit}</dd></div>
        <div class="stat-card"><dt>Memoria</dt><dd class="text-base">{problem.memoryLimit}</dd></div>
        <div class="stat-card"><dt>Resueltos</dt><dd class="text-base">{problem.solvedCount.toLocaleString('es')}</dd></div>
        <div class="stat-card"><dt>Dificultad</dt><dd class="text-base">{problem.difficulty}</dd></div>
      </dl>
    </header>

    <section class="panel-elevated p-6" aria-labelledby="statement-title">
      <h2 id="statement-title" class="text-2xl">Enunciado</h2>
      <div class="mt-4 grid gap-3 text-base leading-relaxed">
        {problem.statement.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <h3 class="mt-6 text-xl">Ejemplos</h3>
      <div class="mt-3 grid gap-4">
        {problem.examples.map((example, idx) => (
          <div class="grid gap-3 md:grid-cols-2">
            <section aria-label={`Entrada del ejemplo ${idx + 1}`}>
              <p class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-muted);">Entrada</p>
              <pre
                class="mt-1 whitespace-pre-wrap break-words rounded-md border p-3 font-mono text-sm md:whitespace-pre"
                style="border-color: var(--color-border); background: var(--color-bg-muted);"
              ><code>{example.input}</code></pre>
            </section>
            <section aria-label={`Salida del ejemplo ${idx + 1}`}>
              <p class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-muted);">Salida</p>
              <pre
                class="mt-1 whitespace-pre-wrap break-words rounded-md border p-3 font-mono text-sm md:whitespace-pre"
                style="border-color: var(--color-border); background: var(--color-bg-muted);"
              ><code>{example.output}</code></pre>
            </section>
          </div>
        ))}
      </div>
    </section>

    <section aria-labelledby="submit-title" class="grid gap-3">
      <h2 id="submit-title" class="text-2xl">Enviar solucion</h2>
      <SubmitForm client:load problemId={problem.id} />
    </section>
  </article>
</BaseLayout>
