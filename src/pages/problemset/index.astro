---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ProblemFilters from '@/components/ProblemFilters';
import { ListFilter } from 'lucide-react';
import { problems, tags } from '@/data/problems';
---

<BaseLayout title="Problemset">
  <div class="grid gap-6">
    <Breadcrumbs items={[{ label: 'Problemset' }]} />
    <section class="hero" aria-labelledby="problemset-title">
      <p class="section-label">Problemset</p>
      <h1 id="problemset-title" class="mt-2 flex items-center gap-2">
        <ListFilter aria-hidden="true" size={32} />
        Lista de problemas
      </h1>
      <p class="text-muted-strong mt-2 max-w-3xl">
        Encuentra ejercicios por titulo, tag o dificultad y abre el enunciado para empezar a resolver.
      </p>
    </section>
    <ProblemFilters client:load problems={problems} tags={tags} />
  </div>
</BaseLayout>
