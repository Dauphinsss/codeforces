---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthForm from '@/components/AuthForm';
import GlossaryTooltip from '@/components/GlossaryTooltip';
---

<BaseLayout title="Entrar">
  <section class="mx-auto grid max-w-2xl gap-5" aria-labelledby="login-title">
    <header class="hero">
      <p class="section-label">Acceso</p>
      <h1 id="login-title" class="mt-2">Entrar a Accessibleforces</h1>
      <p class="mt-2" style="color: var(--color-muted-strong);">
        Usa tu <GlossaryTooltip client:load term="handle" description="Nombre publico que identifica tus envios, perfil y participacion en contests." /> para acceder a la demo.
      </p>
    </header>
    <AuthForm client:load mode="login" />
    <p class="text-center text-sm" style="color: var(--color-muted);">
      ¿No tenes cuenta? <a href="/register" class="font-semibold">Registrate</a>
    </p>
  </section>
</BaseLayout>
