---
import PreferencesPanel from '@/components/PreferencesPanel';
import { CalendarDays, Home, LogIn, Send, Settings, Trophy, UserRound, UserRoundPlus } from 'lucide-react';

const nav = [
  { href: '/', label: 'Inicio', icon: Home },
  { href: '/problemset', label: 'Problemas', icon: Trophy },
  { href: '/contests', label: 'Contests', icon: CalendarDays },
  { href: '/submit', label: 'Enviar', icon: Send },
  { href: '/profile/accessiblecoder', label: 'Perfil', icon: UserRound },
];

const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---

<header
  class="site-header sticky top-0 z-30 border-b backdrop-blur"
>
  <div class="flex min-h-[var(--header-height)] w-full items-center justify-between gap-2 px-3 py-2 sm:gap-3 sm:px-6 lg:px-8">
    <div class="flex min-w-0 items-center gap-2 sm:gap-3">
      <a
        href="/"
        class="brand-link flex min-h-11 items-center gap-2 rounded-md px-1 no-underline"
        aria-label="Accessibleforces, ir al inicio"
      >
        <span class="brand-logo-wrap" aria-hidden="true">
          <img
            src="/logo-claro.png"
            alt=""
            width="435"
            height="120"
            class="brand-logo brand-logo-light"
            loading="eager"
            decoding="async"
          />
          <img
            src="/logo-oscuro.png"
            alt=""
            width="434"
            height="119"
            class="brand-logo brand-logo-dark"
            loading="eager"
            decoding="async"
          />
        </span>
      </a>
      <span class="hidden chip chip-soft lg:inline-flex">Practice arena</span>
    </div>

    <div class="hidden lg:flex lg:items-center lg:justify-between lg:gap-4">
      <nav aria-label="Navegacion principal" class="flex flex-wrap items-center gap-1">
        {nav.map((item) => {
          const active = isActive(item.href);
          const Icon = item.icon;
          return (
            <a
              class="relative inline-flex min-h-11 items-center gap-2 rounded-md px-3 py-2 font-semibold no-underline transition-colors"
              href={item.href}
              aria-current={active ? 'page' : undefined}
              class:list={[active ? 'nav-link-active' : 'text-app']}
            >
              <Icon aria-hidden="true" size={17} />
              {item.label}
            </a>
          );
        })}
      </nav>

      <div class="flex flex-wrap items-center gap-2">
        <a class="btn btn-ghost" href="/enter"><LogIn aria-hidden="true" size={17} />Entrar</a>
        <a class="btn btn-primary" href="/register"><UserRoundPlus aria-hidden="true" size={17} />Registrarse</a>
        <details class="relative">
          <summary class="btn btn-ghost list-none cursor-pointer"><Settings aria-hidden="true" size={17} />Preferencias</summary>
          <div
            class="surface-app border-app absolute right-0 mt-2 w-[min(92vw,24rem)] rounded-md border p-3 shadow-lg"
          >
            <PreferencesPanel client:load />
          </div>
        </details>
      </div>
    </div>

    <details class="mobile-menu-root lg:hidden">
      <summary class="btn btn-ghost list-none cursor-pointer" aria-label="Abrir menu de navegacion">
        <span aria-hidden="true" class="grid gap-1">
          <span class="menu-line menu-line-top block h-0.5 w-5 rounded"></span>
          <span class="menu-line menu-line-middle block h-0.5 w-5 rounded"></span>
          <span class="menu-line menu-line-bottom block h-0.5 w-5 rounded"></span>
        </span>
      </summary>
      <div
        class="mobile-menu-panel content-start gap-4 overflow-y-auto border-y p-4 shadow-lg lg:hidden"
      >
        <nav aria-label="Navegacion principal movil" class="container grid gap-2">
          {nav.map((item) => {
            const active = isActive(item.href);
            const Icon = item.icon;
            return (
              <a
                class="inline-flex min-h-11 w-full items-center gap-2 rounded-md px-3 py-3 font-semibold no-underline"
                href={item.href}
                aria-current={active ? 'page' : undefined}
                class:list={[active ? 'nav-link-active' : 'text-app']}
              >
                <Icon aria-hidden="true" size={17} />
                {item.label}
              </a>
            );
          })}
        </nav>
        <div class="container grid gap-2">
          <a class="btn btn-ghost justify-start" href="/enter"><LogIn aria-hidden="true" size={17} />Entrar</a>
          <a class="btn btn-primary justify-start" href="/register"><UserRoundPlus aria-hidden="true" size={17} />Registrarse</a>
        </div>
        <div class="border-app container border-t pt-3">
          <PreferencesPanel client:load />
        </div>
      </div>
    </details>
  </div>
</header>
